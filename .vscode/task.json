{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "process",
            "label": "Compilar benchmark",
            "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
            "args": [
                "-std=c++17",
                "-O2",
                "-I", "${workspaceFolder}/core",
                "${workspaceFolder}/bench/benchmark.cpp",
                "${workspaceFolder}/core/QuadTree.cpp",
                "${workspaceFolder}/core/Simulation.cpp",
                "${workspaceFolder}/core/BruteForce.cpp",
                "${workspaceFolder}/core/Distribution.cpp",
                "-o",
                "${workspaceFolder}/bench/main.exe"
            ],
            "problemMatcher": ["$gcc"]
        },
        {
            "type": "process",
            "label": "Ejecutar benchmark",
            "command": "${workspaceFolder}/bench/main.exe",
            "dependsOn": "Compilar benchmark",
            "group": { "kind": "build", "isDefault": true },
            "presentation": { "reveal": "always", "panel": "shared", "clear": true }
        }
    ]
}